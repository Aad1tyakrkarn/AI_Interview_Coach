# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=interview_platform
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@interviewprep.com

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RESUMES=resumes
S3_BUCKET_VIDEOS=videos
S3_BUCKET_AUDIO=audio

# Python ML Service
ML_SERVICE_URL=http://python-ml:8000
LLM_MODEL_PATH=/models/mistral-7b
WHISPER_MODEL=base

# Frontend
VITE_API_URL=http://localhost/api/v1
VITE_WS_URL=ws://localhost/ws
VITE_ML_URL=http://localhost:8000

# Security
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Node
NODE_ENV=development
PORT=3000
